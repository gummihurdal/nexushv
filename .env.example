# NexusHV Environment Configuration
# Copy to .env and customize for your deployment

# JWT Authentication
NEXUSHV_JWT_SECRET=change-this-to-a-random-64-char-string
# Generate with: openssl rand -hex 32

# RBAC Enforcement (set to true for production)
NEXUSHV_ENFORCE_AUTH=false

# TLS (optional, set paths to enable HTTPS)
# NEXUSHV_TLS_CERT=/opt/nexushv/certs/nexushv.crt
# NEXUSHV_TLS_KEY=/opt/nexushv/certs/nexushv.key

# HA Daemon URL (for API proxy)
NEXUSHV_HA_URL=http://localhost:8081

# Ollama (AI model server)
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=nexushv-ai

# API Server
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1

# HA Daemon
HA_HOST=127.0.0.1
HA_PORT=8081
HA_PEERS=
# For cluster mode: HA_PEERS=10.0.1.11,10.0.1.12

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
